{
  "name": "@doc-scanner/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p src/vendor/tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --exclude 'node_modules/**' tests/**/*.integration.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "2.0.0",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.9.0",
    "hono": "4.12.15",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
