{
  "name": "@doc-scanner/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p src/vendor/tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "2.0.1",
    "@protontech/drive-sdk": "0.14.10",
    "bcryptjs": "3.0.3",
    "hono": "4.12.16",
    "openpgp": "6.3.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
