{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "lib": ["ES2022", "ESNext.TypedArrays"],
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@vendor/proton-srp/*": ["./src/vendor/proton-srp/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/vendor/**", "tests/**", "dist", "node_modules"]
}
