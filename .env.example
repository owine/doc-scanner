# 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_ENCRYPTION_KEY=
ANTHROPIC_API_KEY=
DB_PATH=./data/app.db
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=true
# Set to true ONLY for local HTTP development (drops the Secure flag on the
# session cookie so it works over plain http://localhost). Leave false in any
# deployed environment — production must serve over HTTPS.
INSECURE_COOKIES=false
